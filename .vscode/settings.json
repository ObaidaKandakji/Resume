{
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-full-2026",
      "command": "/Library/TeX/Distributions/TeXLive-2026.texdist/Contents/Programs/texbin/latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-pdflatex=/Library/TeX/Distributions/TeXLive-2026.texdist/Contents/Programs/texbin/pdflatex %O %S",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk-full-2026",
      "tools": [
        "latexmk-full-2026"
      ]
    }
  ],
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.autoBuild.run": "onSave"
}
